HTTP_ADDR=:8080
# Samakan user/password dengan Postgres kamu. Contoh:
# Docker Compose (service postgres di repo ini): postgres://postgres:postgres@localhost:5432/findings?sslmode=disable
# Homebrew di Mac: biasanya user = nama login macOS, sering tanpa password:
# DATABASE_URL=postgres://namaloginmac@localhost:5432/findings?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/findings?sslmode=disable
JWT_SECRET=ubah-ini-minimal-32-karakter-rahasia-jwt
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=admin
SERVICE_NAME=findings-api
SERVICE_VERSION=0.1.0
